#!/bin/bash

# ================= KONFIGURASI PROTOKOL =================
# Daftar inbound tag yang akan digunakan untuk pengguna baru
readonly INBOUND_TAGS=("VMESS_WS" "VMESS_HU" "VMESS_GRPC")

readonly PROTOCOL_NAME="Vmess Multi-Transport"
readonly PROXIES_PAYLOAD='{"vmess": {}}'
# INBOUNDS_PAYLOAD dibuat secara dinamis dari daftar INBOUND_TAGS
# Pertama, ubah array bash menjadi array JSON
readonly TAGS_JSON=$(printf "%s\n" "${INBOUND_TAGS[@]}" | jq -R . | jq -s .)
# Kedua, masukkan array JSON ke dalam payload
readonly INBOUNDS_PAYLOAD=$(printf '{"vmess": %s}' "$TAGS_JSON")
# =======================================================

# Fungsi untuk menampilkan pesan error dan keluar
error_exit() {
    echo -e "\n[ERROR] $1" >&2
    exit 1
}

# Membaca konfigurasi dari file .env
load_env_config() {
    local ENV_FILE="/etc/marzban/.env"
    if [[ ! -r "$ENV_FILE" ]]; then
        error_exit "File konfigurasi di ${ENV_FILE} tidak ditemukan atau tidak bisa dibaca."
    fi
    while IFS='=' read -r key value; do
        value="${value//\"/}"
        case "$key" in
            "DOMAIN") DOMAIN="$value" ;;
            "ADMIN_USERNAME") ADMIN_USERNAME="$value" ;;
            "ADMIN_PASSWORD") ADMIN_PASSWORD="$value" ;;
        esac
    done < "$ENV_FILE"
    if [[ -z "$DOMAIN" || -z "$ADMIN_USERNAME" || -z "$ADMIN_PASSWORD" ]]; then
        error_exit "Variabel (DOMAIN, ADMIN_USERNAME, ADMIN_PASSWORD) tidak ditemukan atau kosong di ${ENV_FILE}."
    fi
    MARZBAN_URL="https://$DOMAIN"
}

# Pengecekan awal sebelum skrip berjalan
pre_run_checks() {
    if [[ "$(id -u)" -ne 0 ]]; then
        error_exit "Skrip ini harus dijalankan sebagai root atau dengan sudo."
    fi
    for cmd in jq curl tee base64 sed; do
        if ! command -v "$cmd" &> /dev/null; then
            error_exit "Perintah '$cmd' tidak ditemukan. Mohon install terlebih dahulu."
        fi
    done
}

# Mendapatkan token otentikasi dari API Marzban
get_api_token() {
    local token_response
    token_response=$(curl -s --max-time 10 -X POST "${MARZBAN_URL}/api/admin/token" \
        -H "Content-Type: application/x-www-form-urlencoded" \
        --data-urlencode "username=${ADMIN_USERNAME}" \
        --data-urlencode "password=${ADMIN_PASSWORD}")
    API_TOKEN=$(echo "$token_response" | jq -r '.access_token')
    if [[ -z "$API_TOKEN" || "$API_TOKEN" == "null" ]]; then
        error_exit "Gagal mendapatkan token API. Pastikan username/password admin di .env benar dan URL API bisa diakses."
    fi
}

# Meminta input dari pengguna untuk detail akun baru
get_user_input() {
    clear
    echo "=========================================="
    echo "         Membuat Akun ${PROTOCOL_NAME}"
    echo "=========================================="
    read -p "Masukkan Username              : " username
    [[ -z "$username" ]] && error_exit "Username tidak boleh kosong."
    read -p "Masa Aktif (hari, 0=unlimited) : " expire_days
    [[ "$expire_days" =~ ^[0-9]+$ ]] || error_exit "Input masa aktif harus berupa angka."
    read -p "Kuota (GB, 0=unlimited)        : " data_limit_gb
    [[ "$data_limit_gb" =~ ^[0-9]+$ ]] || error_exit "Input kuota harus berupa angka."
}

# Membuat user baru melalui API Marzban
create_user() {
    local expire_timestamp=0
    if [[ "$expire_days" -gt 0 ]]; then
        expire_timestamp=$(date -d "+$expire_days days" +%s)
    fi
    local data_limit_bytes=0
    if [[ "$data_limit_gb" -gt 0 ]]; then
        data_limit_bytes=$((data_limit_gb * 1024 * 1024 * 1024))
    fi
    local reset_strategy="no_reset"
    if [[ "$expire_days" -gt 30 && "$data_limit_gb" -gt 0 ]]; then
        reset_strategy="month"
        echo -e "\nINFO: Masa aktif > 30 hari, kuota akan direset setiap bulan."
    fi
    local json_payload
    json_payload=$(cat <<EOF
{
    "username": "$username", "proxies": $PROXIES_PAYLOAD, "inbounds": $INBOUNDS_PAYLOAD,
    "expire": $expire_timestamp, "data_limit": $data_limit_bytes,
    "data_limit_reset_strategy": "$reset_strategy"
}
EOF
)
    API_RESPONSE=$(curl -s -X POST "$MARZBAN_URL/api/user" \
        -H "Authorization: Bearer $API_TOKEN" \
        -H "Content-Type: application/json" -d "$json_payload" | tee data.txt)
}

# Menampilkan hasil pembuatan akun
display_results() {
    if ! jq -e --arg user "$username" '.username == $user' >/dev/null <<< "$API_RESPONSE"; then
        echo
        error_exit "Gagal membuat akun. Respons mentah dari API (tersimpan di data.txt):\n$(echo "$API_RESPONSE" | jq .)"
    fi

    local uuid expire_ts sub_url
    IFS=$'\t' read -r uuid expire_ts sub_url < <(echo "$API_RESPONSE" | jq -r '[.proxies.vmess.id, .expire, .subscription_url] | @tsv')

    local expire_date_str="Always On"
    if [[ "$expire_days" -gt 0 && "$expire_ts" != "null" && "$expire_ts" -ne 0 ]]; then
        expire_date_str=$(TZ="Asia/Jakarta" LC_TIME=id_ID.UTF-8 date -d "@$expire_ts" '+%d %B %Y, %H:%M WIB')
    fi
    local data_limit_str="Unlimited"
    if [[ "$data_limit_gb" -ne 0 ]]; then
        data_limit_str="${data_limit_gb} GB"
    fi
    local sub_url_full="${MARZBAN_URL}${sub_url}"
    
    # === Mengambil detail untuk setiap protokol dari xray_config.json ===
    local xray_config_file="/var/lib/marzban/xray_config.json"
    local ws_path=$(jq -r '.inbounds[] | select(.tag == "VMESS_WS") | .streamSettings.wsSettings.path' "$xray_config_file")
    local hu_path=$(jq -r '.inbounds[] | select(.tag == "VMESS_HU") | .streamSettings.httpupgradeSettings.path' "$xray_config_file")
    local service_name=$(jq -r '.inbounds[] | select(.tag == "VMESS_GRPC") | .streamSettings.grpcSettings.serviceName' "$xray_config_file")
    # ====================================================================

    clear
    echo "----------------------------------"
    echo "   DETAIL AKUN VMESS MULTI-TRANSPORT"
    echo "----------------------------------"
    printf "%-15s: %s\n" "Username" "$username"
    printf "%-15s: %s\n" "UUID" "$uuid"
    printf "%-15s: %s\n" "Domain/Host" "$DOMAIN"
    echo "----------------------------------"
    echo "   DETAIL TRANSPORT"
    echo "----------------------------------"
    printf "%-15s: %s\n" "Path (WS)" "$ws_path"
    printf "%-15s: %s\n" "Path (HU)" "$hu_path"
    printf "%-15s: %s\n" "Service Name" "$service_name"
    echo "----------------------------------"
    printf "%-15s: %s\n" "Masa Aktif" "$expire_date_str"
    printf "%-15s: %s\n" "Limit Kuota" "$data_limit_str"
    if [[ "$expire_days" -gt 30 && "$data_limit_gb" -gt 0 ]]; then
        printf "%-15s: %s\n" "Reset Kuota" "Setiap Bulan"
    fi
    printf "%-15s: %s\n" "Subscription" "$sub_url_full"
    echo "----------------------------------"
    
    # === Loop untuk menampilkan semua link yang dihasilkan ===
    jq -r '.links[]' <<< "$API_RESPONSE" | while IFS= read -r link; do
        # Ekstrak konten base64 dari link vmess
        local b64_part
        b64_part=$(echo "$link" | sed 's/vmess:\/\///')
        
        # Decode base64 dan ambil tipe jaringan (net) dan tipe tls
        local net_type tls_type
        net_type=$(echo "$b64_part" | base64 -d 2>/dev/null | jq -r '.net')
        tls_type=$(echo "$b64_part" | base64 -d 2>/dev/null | jq -r '.tls')
        
        local label=""
        if [[ "$net_type" == "ws" ]]; then label="VMESS WS"
        elif [[ "$net_type" == "httpupgrade" ]]; then label="VMESS HU"
        elif [[ "$net_type" == "grpc" ]]; then label="VMESS GRPC"
        else label="LINK TIDAK DIKENALI"
        fi

        if [[ "$tls_type" == "tls" ]]; then label="$label TLS"
        else label="$label NTLS"
        fi
        
        printf "%-15s:\n" "$label"
        echo "$link"
        echo ""
    done
    echo "----------------------------------"
    echo ""
}

# --- Alur Eksekusi Utama Skrip ---
main() {
    pre_run_checks
    load_env_config
    get_api_token
    get_user_input
    create_user
    display_results
}

# Menjalankan fungsi utama
main "$@"
